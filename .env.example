# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/fraud_detection_db

# Redis Configuration (for caching and real-time features)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration (for streaming)
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=fraud-detection-consumer
KAFKA_TOPIC=transactions

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Model Configuration
MODEL_PATH=models/latest/
MODEL_VERSION=1.0.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Monitoring Configuration
MLFLOW_TRACKING_URI=mlruns
PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3000

# Privacy & Security
ENCRYPTION_KEY=your-secret-encryption-key-here
FEDERATED_LEARNING_ENABLED=false
DIFFERENTIAL_PRIVACY_EPSILON=1.0

# Cloud Storage (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=alerts@example.com
